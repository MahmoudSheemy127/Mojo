# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ───────────────────────────────────────────────
dist/
build/

# ── Environment & secrets ──────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
# keep .env.example tracked — it documents required vars

# ── Prisma ────────────────────────────────────────────────────
# Generated client (regenerated via prisma generate)
node_modules/.prisma/
# Local SQLite dev database if ever used
*.db
*.db-journal

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino*.log

# ── Test & coverage ───────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ── NestJS ────────────────────────────────────────────────────
# Incremental compilation cache
.tsbuildinfo

# ── OS artifacts ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Docker ────────────────────────────────────────────────────
# Local override files (never commit secrets in compose overrides)
docker-compose.override.yml
docker-compose.local.yml

# ── Sentry ────────────────────────────────────────────────────
# Source maps are uploaded to Sentry at build time and deleted from dist
dist/**/*.map
.sentryclirc

# ── Misc tooling ──────────────────────────────────────────────
.eslintcache
.cache/
tmp/
temp/