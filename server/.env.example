# .env.example

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://app:app@localhost:5432/chat

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_TTL=2592000

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── App ───────────────────────────────────────────────────────
PORT=4000
WEB_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost
NODE_ENV=development

# ── Observability ─────────────────────────────────────────────
# SENTRY_DSN empty disables Sentry cleanly (local/dev/test never emit).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development          # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1           # fraction of requests traced
SENTRY_PROFILES_SAMPLE_RATE=0.1         # relative to traced requests
LOG_LEVEL=debug                         # debug local, info staging, warn/info prod